# Image Generation API Keys
# Copy this file to .env and fill in your key.
# NEVER commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env and fill in the key for your provider

# Alibaba Cloud Bailian wan2.6
# Get key: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=

# OpenAI DALL-E 3
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stability AI
# Get key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Local Stable Diffusion WebUI (no key needed)
# Uncomment to customize endpoint:
# SD_ENDPOINT=http://localhost:7860

# ComfyUI (no key needed)
# Uncomment to customize endpoint:
# COMFYUI_ENDPOINT=http://localhost:8188
